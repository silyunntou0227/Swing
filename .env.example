# ============================================================
# 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
#   cp .env.example .env
# ============================================================

# --- J-Quants API ---
JQUANTS_API_KEY=

# --- Discord ---
DISCORD_WEBHOOK_URL=

# --- LINE Messaging API ---
# LINE Developers Console → Messaging API タブ → Channel access token
LINE_CHANNEL_TOKEN=
# LINE Developers Console → Basic settings → Your user ID (U で始まる33文字)
LINE_USER_ID=

# --- ニュース・開示 ---
NEWS_API_KEY=
EDINET_API_KEY=

# --- ログレベル (DEBUG / INFO / WARNING) ---
LOG_LEVEL=INFO
